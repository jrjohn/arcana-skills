# ============================================
# Environment Variables Template
# DevOps Skill — Docker Compose Deployments
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.template .env
#
# NEVER commit .env to version control!
# ============================================

# ── Application ─────────────────────────────
PROJECT_NAME={{PROJECT_NAME}}
IMAGE_TAG=1.0.0
APP_PORT=3000

# ── Docker Registry ─────────────────────────
REGISTRY=localhost:5000

# ── Database (staging/prod) ─────────────────
DB_PASSWORD=changeme

# ── Remote Deploy (prod) ────────────────────
# Required for: deploy.sh prod / deploy.sh remote
SSH_USER=deploy
SSH_HOST=
REMOTE_COMPOSE_DIR=/opt/docker/{{PROJECT_NAME}}

# ── Health Check ────────────────────────────
HEALTH_CHECK_URL=
HEALTH_CHECK_TIMEOUT=60

# ── Notifications (optional) ────────────────
# SLACK_WEBHOOK_URL=
# NOTIFICATION_CHANNEL=

# ── K8s (optional, only if using k8s) ───────
# KUBECONFIG=~/.kube/config
# K8S_NAMESPACE={{PROJECT_NAME}}
