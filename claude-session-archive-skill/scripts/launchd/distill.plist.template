<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.<USERNAME>.crs-distill</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/<USERNAME>/claude-archive/distill-backfill.sh</string>
    </array>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>Nice</key>
    <integer>10</integer>
    <key>StandardOutPath</key>
    <string>/Users/<USERNAME>/claude-archive/distill-backfill.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/<USERNAME>/claude-archive/distill-backfill.log</string>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
