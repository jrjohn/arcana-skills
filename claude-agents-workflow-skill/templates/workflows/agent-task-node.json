{
  "openapi": "3.0.3",
  "info": {
    "title": "agent-task-node",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://agent-task-node:8090"
    }
  ],
  "paths": {
    "/task/diagnose": {
      "post": {
        "operationId": "diagnose",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "job": {
                    "type": "string"
                  },
                  "buildUrl": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "diagnosis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cause": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string"
                    },
                    "fixable": {
                      "type": "boolean"
                    },
                    "proposedAction": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/task/fix": {
      "post": {
        "operationId": "fix",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "job": {
                    "type": "string"
                  },
                  "cause": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "fix result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "action": {
                      "type": "string"
                    },
                    "prUrl": {
                      "type": "string"
                    },
                    "branch": {
                      "type": "string"
                    },
                    "summary": {
                      "type": "string"
                    },
                    "pushed": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/task/merge": {
      "post": {
        "operationId": "merge",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prUrl": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "merge result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "merged": {
                      "type": "boolean"
                    },
                    "reason": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/task/sweep": {
      "post": {
        "operationId": "sweep",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "sweep result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "checked": {
                      "type": "integer"
                    },
                    "red": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "retriggered": {
                      "type": "integer"
                    },
                    "summary": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}