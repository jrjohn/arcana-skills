<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{TITLE}}</title>
<style>
:root{
  --bg:#f6f7fb; --ink:#1e293b; --muted:#64748b; --line:#e7eaf3;
  --accent:#4f46e5; --accent2:#0ea5e9; --card:#ffffff; --soft:#f1f5f9;
  --warn:#b45309; --bad:#dc2626;
}
*{box-sizing:border-box;}
body{margin:0;background:var(--bg);color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Microsoft JhengHei",Inter,sans-serif;
  line-height:1.6;-webkit-font-smoothing:antialiased;}
.wrap{max-width:1180px;margin:0 auto;padding:32px 24px 60px;}
header.hd{margin-bottom:8px;}
header.hd h1{font-size:1.9em;font-weight:700;letter-spacing:-0.02em;margin:0 0 6px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;background-clip:text;color:transparent;}
header.hd .sub{color:var(--muted);font-size:0.95em;}
.card{background:var(--card);border:1px solid var(--line);border-radius:16px;
  padding:22px 26px;margin:18px 0;box-shadow:0 1px 2px rgba(16,24,40,.04),0 8px 24px -16px rgba(16,24,40,.12);}
.card>h2{margin:0 0 14px;font-size:1.15em;font-weight:650;color:var(--ink);
  display:flex;align-items:center;gap:9px;}
.card>h2 .tag{font-size:.62em;font-weight:600;color:var(--accent);background:#eef2ff;
  padding:2px 8px;border-radius:999px;letter-spacing:.02em;}
h3{font-size:1em;color:#334155;margin:16px 0 6px;}
.hero{padding:10px 12px;}
.hero h2{padding:12px 14px 0;}
#mindmap{display:block;width:100%;height:560px;}
.legend{color:var(--muted);font-size:.82em;padding:0 14px 12px;}
pre.mermaid{background:#fbfcfe;border:1px solid var(--line);border-radius:12px;padding:14px;overflow:auto;text-align:center;}
table{width:100%;border-collapse:collapse;font-size:.88em;margin:4px 0 12px;}
th,td{text-align:left;padding:8px 11px;border-bottom:1px solid var(--line);vertical-align:top;}
th{font-weight:600;color:var(--muted);font-size:.92em;}
tr:hover td{background:var(--soft);}
code{font-family:"SF Mono",ui-monospace,Consolas,monospace;font-size:.86em;background:var(--soft);
  padding:1px 6px;border-radius:6px;color:#475569;}
blockquote{border-left:3px solid var(--accent2);margin:10px 0;padding:6px 16px;color:var(--muted);
  background:linear-gradient(90deg,#f0f9ff,transparent);border-radius:0 10px 10px 0;}
ul,ol{padding-left:1.3em;}
.cards2{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.cards2 .card{margin:0;}
.risk h2{color:var(--bad);} .risk h2 .tag{color:var(--bad);background:#fef2f2;}
.myth h2{color:var(--warn);} .myth h2 .tag{color:var(--warn);background:#fffbeb;}
@media(max-width:780px){.cards2{grid-template-columns:1fr;} #mindmap{height:420px;}}
footer{max-width:1180px;margin:8px auto 0;text-align:center;color:#94a3b8;font-size:.78em;}
a{color:var(--accent);text-decoration:none;} a:hover{text-decoration:underline;}
.markmap-node circle{cursor:pointer;}
</style>
</head>
<body>
<div class="wrap">
  <header class="hd">
    <h1>{{TITLE}}</h1>
    <div class="sub">interactive knowledge graph · archive-derived snapshot</div>
  </header>
  <div class="card hero">
    <h2>🧠 互動心智圖 <span class="tag">點節點展開／收合・滾輪縮放・拖曳平移</span></h2>
    <!-- markmap source (no .markmap class → we render explicitly so we control fit()) -->
    <script type="text/template" id="mm-src">
{{MINDMAP}}
</script>
    <svg id="mindmap"></svg>
  </div>
  <div id="doc">Loading…</div>
</div>
<footer>Generated by <a href="https://github.com/jrjohn/arcana-skills" target="_blank">knowledge-graph-skill</a> · interactive knowledge graph</footer>

<script type="text/markdown" id="spec">
{{CONTENT}}
</script>

<script src="{{MARKED_SRC}}"></script>
<script src="{{MERMAID_SRC}}"></script>
<script>
// Body = prose + ```mermaid (the markmap block is rendered statically above by the autoloader).
const raw = document.getElementById('spec').textContent.replace(/^\n/, '');
const parts = raw.split(/```mermaid\s*\n([\s\S]*?)```/g); // [prose, code, prose, code, ...]
const doc = document.getElementById('doc');
doc.innerHTML = '';
for (let i = 0; i < parts.length; i++) {
  if (i % 2 === 1) {
    const card = document.createElement('div'); card.className = 'card';
    const pre = document.createElement('pre'); pre.className = 'mermaid'; pre.textContent = parts[i].trimEnd();
    card.appendChild(pre); doc.appendChild(card);
  } else if (parts[i].trim()) {
    const seg = document.createElement('div'); seg.innerHTML = marked.parse(parts[i]); doc.appendChild(seg);
  }
}
mermaid.initialize({startOnLoad:false, theme:'base', securityLevel:'loose', maxTextSize:120000,
  themeVariables:{primaryColor:'#eef2ff',primaryBorderColor:'#c7d2fe',primaryTextColor:'#1e293b',
    lineColor:'#94a3b8',fontFamily:'-apple-system,Segoe UI,Microsoft JhengHei,sans-serif',
    clusterBkg:'#f8fafc',clusterBorder:'#e2e8f0'},
  flowchart:{htmlLabels:true, curve:'basis', padding:14, nodeSpacing:45, rankSpacing:55}});
mermaid.run({querySelector:'pre.mermaid'});
</script>
<script src="{{MARKMAP_SRC}}"></script>
<script>
// Render the mind map explicitly (the autoloader bundle exposes Transformer/Markmap), so we
// control fit() — auto-init's single fit can fire before layout/fonts settle and leave the
// tree crammed at the origin. We fit on load, again after a short delay, and on resize.
(function(){
  function go(){
    const srcEl = document.getElementById('mm-src');
    if (!srcEl || !window.markmap || !window.markmap.Markmap) { return setTimeout(go, 150); }
    const { Transformer, Markmap, deriveOptions } = window.markmap;
    const { root, frontmatter } = new Transformer().transform(srcEl.textContent);
    const opts = (deriveOptions && frontmatter && frontmatter.markmap) ? deriveOptions(frontmatter.markmap) : undefined;
    const mm = Markmap.create('#mindmap', opts, root);
    const refit = () => { try { mm.fit(); } catch(e){} };
    refit(); setTimeout(refit, 400); setTimeout(refit, 1300);
    window.addEventListener('resize', refit);
  }
  if (document.readyState === 'complete') go(); else window.addEventListener('load', go);
})();
</script>
</body>
</html>
